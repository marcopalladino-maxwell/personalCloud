<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrati - Photo & Video Cloud</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">📸 Photo & Video Cloud</a>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-body p-5">
                        <h2 class="text-center mb-4">Registrati</h2>

                        <% if (error) { %>
                            <div class="alert alert-danger" role="alert">
                                <%= error %>
                            </div>
                            <% } %>

                                <form action="/signup" method="POST">
                                    <div class="mb-3">
                                        <label for="username" class="form-label">Nome utente</label>
                                        <input type="text" class="form-control" id="username" name="username" required>
                                    </div>

                                    <div class="mb-3">
                                        <label for="registrationCode" class="form-label">Codice di Registrazione</label>
                                        <input type="text" class="form-control" id="registrationCode"
                                            name="registrationCode" required
                                            placeholder="Inserisci il codice fornito dall'amministratore">
                                        <div class="form-text">Richiedi il codice all'amministratore del sistema</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="email" class="form-label">Email</label>
                                        <input type="email" class="form-control" id="email" name="email" required>
                                    </div>

                                    <div class="mb-3">
                                        <label for="password" class="form-label">Password</label>
                                        <input type="password" class="form-control" id="password" name="password"
                                            required minlength="6">
                                    </div>

                                    <div class="mb-3">
                                        <label for="confirmPassword" class="form-label">Conferma Password</label>
                                        <input type="password" class="form-control" id="confirmPassword"
                                            name="confirmPassword" required minlength="6">
                                    </div>

                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary btn-lg">Registrati</button>
                                    </div>
                                </form>

                                <div class="text-center mt-3">
                                    <p>Hai già un account? <a href="/login">Accedi qui</a></p>
                                </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>