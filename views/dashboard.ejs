<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Photo & Video Cloud</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">📸 Photo & Video Cloud</a>
            <div class="d-flex">
                <span class="navbar-text me-3">Ciao, <%= username %>!</span>
                <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h2 class="mb-4">Il Tuo Cloud</h2>

        <% if (message) { %>
            <div class="alert alert-info" role="alert">
                <%= message %>
            </div>
            <% } %>

                <!-- Upload Section -->
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">📤 Carica Nuovi File</h5>
                        <form action="/upload" method="POST" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label for="files" class="form-label">Seleziona foto o video (max 10 file, 10MB
                                    ciascuno)</label>
                                <input type="file" class="form-control" id="files" name="files" multiple
                                    accept="image/*,video/*" required>
                                <div class="form-text">Formati supportati: JPG, PNG, GIF, MP4, AVI, MOV, WMV, FLV, MKV
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary">Carica File</button>
                        </form>
                    </div>
                </div>

                <!-- Gallery Section -->
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">🖼️ La Tua Galleria (<%= files.length %> file)</h5>

                        <% if (files.length===0) { %>
                            <div class="alert alert-info" role="alert">
                                Nessun file caricato. Inizia caricando le tue prime foto o video!
                            </div>
                            <% } else { %>
                                <div class="row g-3 mt-2">
                                    <% files.forEach(file=> { %>
                                        <div class="col-md-3 col-sm-6">
                                            <div class="card h-100 shadow-sm">
                                                <div class="media-container">
                                                    <% if (file.isVideo) { %>
                                                        <video controls class="card-img-top">
                                                            <source src="<%= file.path %>" type="video/mp4">
                                                            Il tuo browser non supporta il tag video.
                                                        </video>
                                                        <% } else { %>
                                                            <img src="<%= file.path %>" class="card-img-top"
                                                                alt="<%= file.filename %>">
                                                            <% } %>
                                                </div>
                                                <div class="card-body d-flex flex-column">
                                                    <p class="card-text small text-truncate mb-2"
                                                        title="<%= file.filename %>">
                                                        <%= file.filename %>
                                                    </p>
                                                    <form action="/delete/<%= file.filename %>" method="POST"
                                                        class="mt-auto">
                                                        <button type="submit" class="btn btn-danger btn-sm w-100"
                                                            onclick="return confirm('Sei sicuro di voler eliminare questo file?')">
                                                            🗑️ Elimina
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                        <% }); %>
                                </div>
                                <% } %>
                    </div>
                </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>